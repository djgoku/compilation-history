#!/usr/bin/env bash
#MISE description="Install MELPA check dependencies (package-lint) into .melpa-deps/"
set -euo pipefail

DEPS_DIR="${MISE_PROJECT_DIR:-.}/.melpa-deps"

# Early exit if already installed (glob matches versioned subdirectory)
if compgen -G "$DEPS_DIR/package-lint-*/package-lint.el" >/dev/null 2>&1; then
  echo "Dependencies already installed in $DEPS_DIR"
  exit 0
fi

echo "Installing package-lint into $DEPS_DIR..."
mkdir -p "$DEPS_DIR"

# Discover the current package-lint version from MELPA archive.
# package-refresh-contents only fetches the index — no tar extraction,
# so the Emacs 29/30 container bug does not apply here.
ERR_LOG=$(mktemp)
trap 'rm -f "$ERR_LOG"' EXIT
VERSION=$(emacs --batch \
  --eval "(require 'package)" \
  --eval "(add-to-list 'package-archives '(\"melpa\" . \"https://melpa.org/packages/\") t)" \
  --eval "(package-refresh-contents)" \
  --eval "(let* ((desc (cadr (assq 'package-lint package-archive-contents)))
                 (v (package-desc-version desc)))
            (princ (mapconcat #'number-to-string v \".\")))" \
  2>"$ERR_LOG") || true

if [ -z "$VERSION" ]; then
  echo "ERROR: could not discover package-lint version from MELPA" >&2
  cat "$ERR_LOG" >&2
  rm -f "$ERR_LOG"
  exit 1
fi

if ! [[ "$VERSION" =~ ^[0-9]+(\.[0-9]+)*$ ]]; then
  echo "ERROR: invalid version string: '$VERSION'" >&2
  cat "$ERR_LOG" >&2
  rm -f "$ERR_LOG"
  exit 1
fi
rm -f "$ERR_LOG"

echo "Found package-lint version: $VERSION"

# Download and extract with system tools (bypasses package.el tar bug)
TAR_FILE="$DEPS_DIR/package-lint-${VERSION}.tar"
curl -fsSL "https://melpa.org/packages/package-lint-${VERSION}.tar" -o "$TAR_FILE"
tar xf "$TAR_FILE" -C "$DEPS_DIR"
rm -f "$TAR_FILE"

# Byte-compile for faster loading
PKG_DIR="$DEPS_DIR/package-lint-${VERSION}"
emacs --batch \
  -L "$PKG_DIR" \
  -f batch-byte-compile \
  "$PKG_DIR"/*.el || true

echo "Dependencies installed to $DEPS_DIR"
