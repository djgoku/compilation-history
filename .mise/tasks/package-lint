#!/usr/bin/env bash
#MISE description="Run package-lint for MELPA compliance"
#MISE depends=["deps"]
set -euo pipefail

DEPS_DIR="${MISE_PROJECT_DIR:-.}/.elpaca"
PROJECT="${MISE_PROJECT_DIR:-.}"

# Build load path from all Elpaca-installed packages
LOAD_PATHS=()
for dir in "$DEPS_DIR"/builds/*/; do
  [ -d "$dir" ] && LOAD_PATHS+=("-L" "$dir")
done

# Find all source .el files (exclude test files)
src_files=()
for f in "$PROJECT"/compilation-history*.el; do
  [ -f "$f" ] || continue
  case "$(basename "$f")" in
    test-*) continue ;;
  esac
  src_files+=("$f")
done

echo "Running package-lint on: ${src_files[*]##*/}"

emacs --batch \
  -L "$PROJECT" \
  "${LOAD_PATHS[@]}" \
  --eval "(require 'package-lint)" \
  -f package-lint-batch-and-exit \
  "${src_files[@]}"

echo "OK: package-lint passed"
