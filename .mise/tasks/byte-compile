#!/usr/bin/env bash
#MISE description="Byte-compile and check for warnings"
#MISE depends=["deps"]
set -euo pipefail

DEPS_DIR="${MISE_PROJECT_DIR:-.}/.melpa-deps"
PROJECT="${MISE_PROJECT_DIR:-.}"

# Resolve versioned package-lint directory (newest if multiple exist)
PKG_LINT_DIR=$(compgen -G "$DEPS_DIR/package-lint-*" 2>/dev/null | sort -V | tail -1) || true
EXTRA_LOAD_PATH=""
if [ -n "$PKG_LINT_DIR" ]; then
  EXTRA_LOAD_PATH="-L $PKG_LINT_DIR"
fi

# Find all source .el files (exclude test files)
src_files=()
for f in "$PROJECT"/compilation-history*.el; do
  [ -f "$f" ] || continue
  case "$(basename "$f")" in
    test-*) continue ;;
  esac
  src_files+=("$f")
done

status=0

for src in "${src_files[@]}"; do
  echo "Byte-compiling $(basename "$src")..."
  rm -f "${src}c"

  output=$(emacs --batch \
    -L "$PROJECT" \
    $EXTRA_LOAD_PATH \
    -f batch-byte-compile "$src" 2>&1)

  if echo "$output" | grep -qi "error"; then
    echo "FAIL: $(basename "$src")"
    echo "$output"
    status=1
  elif echo "$output" | grep -qi "warning"; then
    echo "WARN: $(basename "$src")"
    echo "$output"
    status=1
  else
    echo "OK: $(basename "$src")"
  fi

  rm -f "${src}c"
done

exit $status
